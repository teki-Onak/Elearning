// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(STUDENT)
  avatar        String?
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  enrollments          Enrollment[]
  progress             Progress[]
  submissions          QuizSubmission[]
  surveyResponses      SurveyResponse[]
  notifications        Notification[]
  wellbeingLogs        WellbeingLog[]
  forumPosts           ForumPost[]
  forumReplies         ForumReply[]
  achievements         UserAchievement[]
  assignmentsGiven     Assignment[]            @relation("AssignmentsGiven")
  assignmentSubmissions AssignmentSubmission[] @relation("AssignmentSubmissions")
  examsGiven           Exam[]                  @relation("ExamsGiven")
  examAttempts         ExamAttempt[]           @relation("ExamAttempts")
  courseInstructors    CourseInstructor[]      @relation("CourseInstructors")
  unitInstructors      UnitInstructor[]        @relation("UnitInstructors")
  hodCourses           CourseHoD[]             @relation("HoDCourses")
  catAttempts          CATAttempt[]            @relation("CATAttempts")
  chatMembers  ChatMember[]
  chatMessages ChatMessage[]
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// ─────────────────────────────────────────
// COURSES
// ─────────────────────────────────────────

model Course {
  id          String    @id @default(cuid())
  title       String
  description String
  thumbnail   String?
  category    String
  level       Level     @default(BEGINNER)
  duration    Int
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  modules     Module[]
  enrollments Enrollment[]
  tags        CourseTag[]
  assignments Assignment[]
  exams       Exam[]
  instructors CourseInstructor[]
  hods             CourseHoD[]
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Module {
  id               String    @id @default(cuid())
  title            String
  description      String?
  order            Int
  courseId         String
  course           Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  onlineClassLink  String?
  onlineClassDate  DateTime?
  createdAt        DateTime  @default(now())

  lessons          Lesson[]
  unitInstructors  UnitInstructor[]
  assignments      Assignment[]
  cats             CAT[]
}

model Lesson {
  id          String      @id @default(cuid())
  title       String
  content     String
  videoUrl    String?
  duration    Int?
  order       Int
  type        LessonType  @default(TEXT)
  moduleId    String
  module      Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  progress    Progress[]
  quizzes     Quiz[]
  resources   Resource[]
}

enum LessonType {
  TEXT
  VIDEO
  QUIZ
  ASSIGNMENT
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  url       String
  type      String
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model CourseTag {
  id       String @id @default(cuid())
  name     String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// ENROLLMENT & PROGRESS
// ─────────────────────────────────────────

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  status      EnrollmentStatus @default(ACTIVE)

  @@unique([userId, courseId])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model Progress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  timeSpent   Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, lessonId])
}

// ─────────────────────────────────────────
// QUIZZES
// ─────────────────────────────────────────

model Quiz {
  id          String    @id @default(cuid())
  title       String
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  passMark    Int       @default(60)
  createdAt   DateTime  @default(now())

  questions   Question[]
  submissions QuizSubmission[]
}

model Question {
  id        String   @id @default(cuid())
  text      String
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options   Option[]
  order     Int
}

model Option {
  id         String   @id @default(cuid())
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizSubmission {
  id        String    @id @default(cuid())
  userId    String
  quizId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score     Int
  answers   Json
  passed    Boolean
  createdAt DateTime  @default(now())
}

// ─────────────────────────────────────────
// SURVEY
// ─────────────────────────────────────────

model Survey {
  id          String           @id @default(cuid())
  title       String
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())

  questions   SurveyQuestion[]
  responses   SurveyResponse[]
}

model SurveyQuestion {
  id        String       @id @default(cuid())
  text      String
  type      QuestionType @default(MULTIPLE_CHOICE)
  options   String[]
  order     Int
  surveyId  String
  survey    Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  category  String?
}

enum QuestionType {
  MULTIPLE_CHOICE
  RATING
  TEXT
  YES_NO
}

model SurveyResponse {
  id        String   @id @default(cuid())
  userId    String
  surveyId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers   Json
  createdAt DateTime @default(now())

  @@unique([userId, surveyId])
}

// ─────────────────────────────────────────
// WELLBEING TRACKER
// ─────────────────────────────────────────

model WellbeingLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      Int
  stress    Int
  energy    Int
  note      String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// FORUM
// ─────────────────────────────────────────

model ForumPost {
  id        String       @id @default(cuid())
  title     String
  content   String
  userId    String
  courseId  String?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  replies   ForumReply[]
}

model ForumReply {
  id        String    @id @default(cuid())
  content   String
  userId    String
  postId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

// ─────────────────────────────────────────
// ACHIEVEMENTS
// ─────────────────────────────────────────

model Achievement {
  id          String            @id @default(cuid())
  name        String
  description String
  icon        String
  condition   String
  points      Int               @default(10)

  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// ASSIGNMENTS & EXAMS
// ─────────────────────────────────────────

model Assignment {
  id           String               @id @default(cuid())
  title        String
  description  String?
  type         AssignmentType       @default(ASSIGNMENT)
  courseId     String
  course       Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId     String?
  module       Module?              @relation(fields: [moduleId], references: [id])
  instructorId String
  instructor   User                 @relation("AssignmentsGiven", fields: [instructorId], references: [id])
  dueDate      DateTime
  totalMarks   Int                  @default(100)
  createdAt    DateTime             @default(now())

  submissions  AssignmentSubmission[]
}

enum AssignmentType {
  ASSIGNMENT
  PROJECT
  EXAM
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation("AssignmentSubmissions", fields: [studentId], references: [id])
  content      String
  grade        Int?
  feedback     String?
  submittedAt  DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

model Exam {
  id           String         @id @default(cuid())
  title        String
  description  String?
  courseId     String
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User           @relation("ExamsGiven", fields: [instructorId], references: [id])
  duration     Int            @default(60)
  totalMarks   Int            @default(100)
  passMark     Int            @default(50)
  isPublished  Boolean        @default(false)
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime       @default(now())

  questions    ExamQuestion[]
  attempts     ExamAttempt[]
}

model ExamQuestion {
  id      String   @id @default(cuid())
  examId  String
  exam    Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  text    String
  type    String   @default("MCQ")
  options String[]
  answer  String
  marks   Int      @default(1)
  order   Int      @default(0)
}

model ExamAttempt {
  id          String    @id @default(cuid())
  examId      String
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("ExamAttempts", fields: [studentId], references: [id])
  answers     Json      @default("{}")
  score       Int?
  passed      Boolean?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  @@unique([examId, studentId])
}

model CourseInstructor {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User     @relation("CourseInstructors", fields: [instructorId], references: [id])
  assignedAt   DateTime @default(now())

  @@unique([courseId, instructorId])
}
// ─────────────────────────────────────────
// UNIT INSTRUCTOR & HOD
// ─────────────────────────────────────────

model UnitInstructor {
  id           String   @id @default(cuid())
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User     @relation("UnitInstructors", fields: [instructorId], references: [id])
  assignedAt   DateTime @default(now())

  @@unique([moduleId, instructorId])
}

model CourseHoD {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hodId     String
  hod       User     @relation("HoDCourses", fields: [hodId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([courseId, hodId])
}

// ─────────────────────────────────────────
// CAT (Continuous Assessment Test)
// ─────────────────────────────────────────

model CAT {
  id           String        @id @default(cuid())
  title        String
  description  String?
  moduleId     String
  module       Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseId     String
  instructorId String
  duration     Int           @default(30)
  totalMarks   Int           @default(30)
  passMark     Int           @default(50)
  isPublished  Boolean       @default(false)
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime      @default(now())

  questions    CATQuestion[]
  attempts     CATAttempt[]
}

model CATQuestion {
  id      String   @id @default(cuid())
  catId   String
  cat     CAT      @relation(fields: [catId], references: [id], onDelete: Cascade)
  text    String
  type    String   @default("MCQ")
  options String[]
  answer  String
  marks   Int      @default(1)
  order   Int      @default(0)
}

model CATAttempt {
  id          String    @id @default(cuid())
  catId       String
  cat         CAT       @relation(fields: [catId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("CATAttempts", fields: [studentId], references: [id])
  answers     Json      @default("{}")
  score       Int?
  passed      Boolean?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  @@unique([catId, studentId])
}

// ─────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────

model ChatRoom {
  id        String    @id @default(cuid())
  name      String?
  type      String    @default("direct") // direct, group
  courseId  String?
  createdAt DateTime  @default(now())

  messages  ChatMessage[]
  members   ChatMember[]
}

model ChatMember {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([roomId, userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  content   String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([userId])
}
